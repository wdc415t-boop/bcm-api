# ── BeachCombersMania API Server ──────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Anthropic API Key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Server port (Render sets PORT automatically)
PORT=3001

# Allowed origins (comma-separated) — your Hostinger domains
ALLOWED_ORIGINS=https://marcomania.online,https://naplesmania.online,https://bonitamania.online,https://ftmyersmania.online,https://sanibelmania.online,https://captivamania.online,https://beachcombersmania.online,https://marcomainia.online

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Environment
NODE_ENV=production
